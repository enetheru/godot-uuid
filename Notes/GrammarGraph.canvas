		{"id":"1abcc979e4091ec2","type":"text","text":"**string_constant**\n`{regex} \\\".*?\\\"`","x":-620,"y":-80,"width":280,"height":60,"color":"3"},
		{"id":"ab86df306ce6e461","type":"text","text":"**commasep(x)**\n `{regex} [x(,x)\\*]`","x":-620,"y":0,"width":280,"height":60},
		{"id":"5e2145d3793d7165","type":"text","text":"**dec_float_constant**\n`{regex} [-+]?(([.][:digit:]+)|([:digit:]+[.][:digit:]*)|([:digit:]+))([eE][-+]?[:digit:]+)?`","x":-140,"y":400,"width":860,"height":60,"color":"5"},
		{"id":"d4ba5e114ecce060","type":"text","text":"**hex_integer_constant**\n`{regex} [-+]?0[xX][:xdigit:]+`","x":-140,"y":480,"width":860,"height":60,"color":"5"},
		{"id":"36d7c854fb0f1afe","type":"text","text":"**hex_float_constant**\n`{regex} [-+]?0[xX](([.][:xdigit:]+)|([:xdigit:]+[.][:xdigit:]*)|([:xdigit:]+))([pP][-+]?[:digit:]+)`\n","x":-140,"y":560,"width":860,"height":60,"color":"5"},
		{"id":"e001076a6c758bcd","type":"text","text":"","x":660,"y":640,"width":60,"height":60,"color":"5"},
