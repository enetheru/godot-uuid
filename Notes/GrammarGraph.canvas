		{"id":"0fb6f685c01040a0","type":"text","text":"**boolean_constant** \n`{regex} true|false`","x":-620,"y":720,"width":280,"height":60,"color":"1"},
		{"id":"d11f3d71873b2492","type":"text","text":"**ident** = \n`{regex} [a-zA-Z_][a-zA-Z0-9_]*`","x":-620,"y":240,"width":280,"height":60,"color":"2"},
